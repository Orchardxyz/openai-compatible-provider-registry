---
import SitePage from "../../components/SitePage.astro";
import { htmlLangFor } from "../../i18n/config";
import { getMessages } from "../../i18n/messages";

const locale = "zh-CN";
const messages = getMessages(locale);
const htmlLang = htmlLangFor(locale);
const pageTitle = messages.pageTitle;
---

<SitePage
  locale={locale}
  messages={messages}
  htmlLang={htmlLang}
  pageTitle={pageTitle}
/>