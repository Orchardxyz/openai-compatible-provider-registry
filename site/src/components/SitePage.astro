---
import "@fontsource/ibm-plex-sans/latin-400.css";
import "@fontsource/ibm-plex-sans/latin-500.css";
import "@fontsource/ibm-plex-sans/latin-600.css";
import "@fontsource/ibm-plex-mono/latin-400.css";
import "@fontsource/ibm-plex-mono/latin-500.css";

import "../styles/global.css";

import Topbar from "./Topbar.astro";
import UsageExamples from "./UsageExamples.astro";
import { PlaygroundApp } from "./PlaygroundApp";
import type { SiteLocale } from "../i18n/config";
import type { SiteMessages } from "../i18n/messages";

interface Props {
  locale: SiteLocale;
  messages: SiteMessages;
  htmlLang: string;
  pageTitle: string;
}

const { locale, messages, htmlLang, pageTitle } = Astro.props;

const productionCsp =
  "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src https:; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none';";
const isProduction = import.meta.env.PROD;
const cspContent = isProduction ? productionCsp : "";
const themeStorageKey = "provider-registry-theme";
const basePath = import.meta.env.BASE_URL;
const normalizedBasePath = basePath.endsWith("/") ? basePath : `${basePath}/`;
const faviconSvgHref = `${normalizedBasePath}favicon.svg`;
const faviconIcoHref = `${normalizedBasePath}favicon.ico`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={faviconSvgHref} type="image/svg+xml" />
    <link rel="alternate icon" href={faviconIcoHref} />
    {cspContent && (
      <meta http-equiv="Content-Security-Policy" content={cspContent} />
    )}
    <script is:inline define:vars={{ themeStorageKey }}>
      try {
        const storedTheme = window.localStorage.getItem(themeStorageKey);
        const resolvedTheme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";

        document.documentElement.dataset.theme = resolvedTheme;
      } catch {
        document.documentElement.dataset.theme = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches
          ? "dark"
          : "light";
      }
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="shell">
      <Topbar
        locale={locale}
        messages={messages}
        basePath={basePath}
        themeStorageKey={themeStorageKey}
      />
      <UsageExamples
        eyebrow={messages.heroEyebrow}
        usageCardEsmLabel={messages.usageCardEsmLabel}
        usageCardCdnLabel={messages.usageCardCdnLabel}
      />
      <PlaygroundApp client:load messages={messages} />
    </div>
  </body>
</html>
