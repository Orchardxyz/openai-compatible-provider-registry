---
import type { SiteLocale } from "../i18n/config";
import type { SiteMessages } from "../i18n/messages";
import { GITHUB_URL, PACKAGE_NAME } from "../lib/site-constants";

interface Props {
  locale: SiteLocale;
  messages: SiteMessages;
  basePath: string;
  themeStorageKey: string;
}

const { locale, messages, basePath, themeStorageKey } = Astro.props;

const normalizedBase = basePath.endsWith("/") ? basePath : `${basePath}/`;
const enHref = `${normalizedBase}`;
const zhHref = `${normalizedBase}zh-cn/`;
---

<header class="topbar">
  <a class="topbar__brand" href="./" aria-label={messages.brandAriaLabel}>
    {PACKAGE_NAME}
  </a>
  <div class="topbar__actions">
    <div
      class="language-switcher"
      role="group"
      aria-label={messages.languageSwitcherAriaLabel}
    >
      <a
        class={`language-switcher__link${locale === "en" ? " language-switcher__link--active" : ""}`}
        href={enHref}
        aria-current={locale === "en" ? "true" : undefined}
      >
        {messages.languageEn}
      </a>
      <a
        class={`language-switcher__link${locale === "zh-CN" ? " language-switcher__link--active" : ""}`}
        href={zhHref}
        aria-current={locale === "zh-CN" ? "true" : undefined}
      >
        {messages.languageZh}
      </a>
    </div>

    <div
      class="theme-toggle"
      role="group"
      aria-label={messages.themeSwitcherAriaLabel}
      data-theme-storage-key={themeStorageKey}
    >
      <button
        type="button"
        class="theme-toggle__button"
        data-theme-choice="light"
        aria-pressed="false"
      >
        {messages.themeLight}
      </button>
      <button
        type="button"
        class="theme-toggle__button"
        data-theme-choice="dark"
        aria-pressed="false"
      >
        {messages.themeDark}
      </button>
    </div>

    <a
      class="icon-link"
      href={GITHUB_URL}
      target="_blank"
      rel="noreferrer noopener"
      aria-label={messages.githubAriaLabel}
      title={messages.githubTitle}
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M12 2C6.48 2 2 6.58 2 12.22c0 4.5 2.87 8.32 6.84 9.67.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.88-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.58 2.36 1.12 2.94.85.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.09 0-1.13.39-2.06 1.03-2.78-.1-.26-.45-1.31.1-2.73 0 0 .84-.27 2.75 1.06A9.3 9.3 0 0 1 12 6.84c.85 0 1.7.12 2.5.36 1.9-1.33 2.74-1.06 2.74-1.06.56 1.42.21 2.47.1 2.73.64.72 1.03 1.65 1.03 2.78 0 3.96-2.34 4.82-4.57 5.08.36.32.68.95.68 1.92 0 1.39-.01 2.51-.01 2.85 0 .27.18.6.69.49A10.24 10.24 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z"
          fill="currentColor"
        />
      </svg>
    </a>
  </div>
</header>

<script is:inline>
  (() => {
    const toggle = document.querySelector(".theme-toggle");
    if (!toggle) return;
    const storageKey = toggle.getAttribute("data-theme-storage-key");
    const buttons = toggle.querySelectorAll("[data-theme-choice]");

    function syncAria() {
      const current = document.documentElement.dataset.theme;
      buttons.forEach((btn) => {
        const choice = btn.getAttribute("data-theme-choice");
        const isActive = choice === current;
        btn.setAttribute("aria-pressed", String(isActive));
        btn.classList.toggle("theme-toggle__button--active", isActive);
      });
    }

    function setTheme(next) {
      document.documentElement.dataset.theme = next;
      try {
        if (storageKey) window.localStorage.setItem(storageKey, next);
      } catch {}
      syncAria();
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const choice = btn.getAttribute("data-theme-choice");
        if (choice === "light" || choice === "dark") setTheme(choice);
      });
    });

    syncAria();
  })();
</script>