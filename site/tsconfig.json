{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["astro/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "@registry/*": ["../src/*"]
    }
  },
  "include": ["src", ".astro/types.d.ts", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}